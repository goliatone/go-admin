    diff_dir="${WEBCAP_DIFF_DIR:-webcap-output/translation-dashboard-ssr/artifacts/diff}"

    if [ ! -f "${reference_dir}/${name}.png" ] || [ ! -f "${current_dir}/${name}.png" ]; then
        echo "Skipping ${name} diff; missing reference or current capture"
