    _translation_dashboard_ssr_webcap:shot exchange "/admin/translations/exchange?channel=${channel}" '#translation-exchange-app' || return 1

    echo "Current captures written to ${WEBCAP_OUTPUT_DIR:-webcap-output/translation-dashboard-ssr/artifacts/current}"
}

