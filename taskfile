}

function go:baseline:update:golangci-lint {
    local golangci_lint_bin
    local version
    local baseline_path
    local module
    local module_script
    local tmp_baseline_path
    local tmp_dir
    local -a patterns=()

    version="$(_go:golangci_lint_version)" || return 1
    golangci_lint_bin=$(_go:golangci_lint:ensure "${version}") || return 1
    baseline_path="${GO_QUALITY_BASELINE_DIR}/golangci-lint.txt"
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/go-admin-golangci-baseline.XXXXXX")" || return 1
        while IFS= read -r module; do
            module_script=$(_go:module_relative_path "${module}" "${GO_QUALITY_BASELINE_SCRIPT}")
            tmp_baseline_path="${tmp_dir}/${module//\//_}.txt"
            if [ "${module}" = "." ]; then
                GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${module_script}" update golangci-lint "${tmp_baseline_path}" ./... || { rm -rf "${tmp_dir}"; return 1; }
            else
                (cd "${module}" && GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${module_script}" update golangci-lint "${tmp_baseline_path}" ./...) || { rm -rf "${tmp_dir}"; return 1; }
            fi
        done < <(_go:module_dirs)
        mkdir -p "$(dirname "${baseline_path}")"
        cat "${tmp_dir}"/*.txt | sort -u >"${baseline_path}"
        rm -rf "${tmp_dir}"
        echo "Wrote golangci-lint baseline with $(wc -l <"${baseline_path}" | tr -d ' ') findings to ${baseline_path}."
        return 0
    fi

    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${GO_QUALITY_BASELINE_SCRIPT}" update golangci-lint "${baseline_path}" "${patterns[@]}"
}

