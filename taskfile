}

function go:lint {
    local golangci_lint_bin
    local version
    local -a patterns=()

    version="$(_go:golangci_lint_version)" || return 1
    golangci_lint_bin=$(_go:golangci_lint:ensure "${version}") || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${golangci_lint_bin}" run ./...
        return $?
    fi

    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
