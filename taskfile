##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message
    local release_tag
    local quickstart_tag
    local current_branch
    local release_notes_file
    local release_notes_enabled
    local release_state_dir
    local release_original_head
    local release_commit_created
    local release_root_tag_created
    local release_quickstart_tag_created

    level=""
    message=""
    release_notes_file="${RELEASE_NOTES_FILE:-.release-notes.md}"
    release_notes_enabled=1

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            patch|minor|major)
                if [ -n "${level}" ]; then
                    echo "Release level specified more than once" >&2
                    return 2
                fi
                level=$1
                shift
            ;;
            --notes|--notes-file)
                shift
                if [ -z "${1:-}" ]; then
                    echo "--notes requires a file path" >&2
                    return 2
                fi
                release_notes_file=$1
                shift
            ;;
            --no-release-notes)
                release_notes_enabled=0
                shift
            ;;
            --)
                shift
                while [[ "$#" -gt 0 ]]; do
                    if [ -z "${message}" ]; then
                        message=$1
                    else
                        message="${message} $1"
                    fi
                    shift
                done
            ;;
            -*)
                echo "Invalid release option: $1" >&2
                return 2
            ;;
            *)
                if [ -z "${message}" ]; then
                    message=$1
                else
                    message="${message} $1"
                fi
                shift
            ;;
        esac
    done

    level=${level:-"patch"}

    # Fetch all changes from origin
    git fetch --all --tags || return 1

    # Keep the local branch current without rewriting local release commits.
    git pull --ff-only --tags || return 1

    # Release commits are generated from a clean tracked tree. Untracked local
    # notes and artifacts are allowed because they are not part of the release.
    if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
        echo "Tracked working tree changes are present; commit or stash them before release." >&2
        git status --short --untracked-files=no >&2
        return 1
    fi

    release_state_dir=$(mktemp -d "${TMPDIR:-/tmp}/go-admin-release.XXXXXX") || return 1
    release_original_head=$(git rev-parse HEAD) || {
        release:transaction:cleanup "${release_state_dir}"
        return 1
    }
    release_commit_created=0
    release_root_tag_created=0
    release_quickstart_tag_created=0
    release:transaction:backup "${release_state_dir}" "${release_notes_file}" || {
        release:transaction:cleanup "${release_state_dir}"
        return 1
    }

    (
    trap 'release:transaction:finish "$?"' EXIT

    # Tags are the published release source of truth. If a prior release was
    # tagged outside this task, advance .version before calculating the next tag.
    version:sync_from_tags || exit 1

    # Bump our version
    tag=$(version:bump "${level}") || exit 1
    release_tag="v${tag}"
    quickstart_tag="quickstart/v${tag}"

    if git rev-parse -q --verify "refs/tags/${release_tag}" >/dev/null; then
        echo "Release tag already exists: ${release_tag}" >&2
        exit 1
    fi

    if git rev-parse -q --verify "refs/tags/${quickstart_tag}" >/dev/null; then
        echo "Quickstart release tag already exists: ${quickstart_tag}" >&2
        exit 1
    fi

    # Set message: default to New major|minor|patch release: vx.x.x
    message=${message:-"New ${level} release: v${tag}"}

    # Update version file
    version:set "${tag}" || exit 1

    # Prepare the acyclic published modules for their atomically published tags.
    quickstart:sync "${tag}" || exit 1

    # Generate changelog before tagging so release tags include their notes.
    if [ "${release_notes_enabled}" -eq 1 ]; then
        release:changelog:generate "${release_tag}" "${release_notes_file}" || exit 1
    else
        git cliff --tag "${release_tag}" --output CHANGELOG.md || exit 1
    fi

    # Add updated version file to git
    git add "${VERSION_FILE}" CHANGELOG.md go.mod go.sum || exit 1
    if [ -f "quickstart/go.mod" ]; then
        git add quickstart/go.mod quickstart/go.sum || exit 1
    fi
    git commit -m "Bump version: v${tag}" || exit 1
    release_commit_created=1

    # Create a new tag
    git tag -a "${release_tag}" -m "${message}" || exit 1
    release_root_tag_created=1
    git tag -a "${quickstart_tag}" -m "Quickstart release: v${tag}" || exit 1
    release_quickstart_tag_created=1

    current_branch=$(git symbolic-ref --short HEAD) || exit 1

    # Push branch and release tags together so the remote is not left half-published.
    git push --atomic origin "HEAD:${current_branch}" \
        "refs/tags/${release_tag}" \
        "refs/tags/${quickstart_tag}" || exit 1
    )
}

##########################################
# Help and auxiliary functions
##########################################

## Show function code
function help:show {
    declare -f "$1"
}

function help {
    echo ""
    echo "$0 <task> [...arguments]"
    echo ""
    echo "Project: ${PROJECT}"
    echo ""
    echo "Tasks:"
    compgen -A function | grep -v '^_' | cat -n
    echo ""

    prog="$0"
    me=$(basename "$prog")

    grep -e '^##[[:space:]]' -e '^##$' "$prog" | sed -e 's/^##//' -e "s/_PROG_/$me/" 2>&1 | less
}

TIMEFORMAT="Task completed in %3lR"
if [[ "${BASH_SOURCE[0]}" != "$0" ]]; then
    return 0
fi
if [ "$#" -eq 0 ]; then
    set -- help
fi

time "$@"
exit $?
