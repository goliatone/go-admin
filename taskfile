##
## -----
##
## release:contracts:refresh
##
## Recompute and persist esign contract guard snapshots and
## synchronize the required Track C ledger entry hash marker.
function release:contracts:refresh {
    local repo_root
    local go_bin

    repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

    if command -v go >/dev/null 2>&1; then
        go_bin="$(command -v go)"
    elif [ -x "/Users/goliatone/.g/go/bin/go" ]; then
        go_bin="/Users/goliatone/.g/go/bin/go"
    else
        echo "go binary not found in PATH or /Users/goliatone/.g/go/bin/go"
        return 1
    fi

    (
        cd "${repo_root}" || exit "$?"

        local refresh_script
        mkdir -p "${repo_root}/.tmp"
        refresh_script="${repo_root}/.tmp/release_contract_refresh.$$.$RANDOM.go"

        cat > "${refresh_script}" <<'EOF'
package main

import (
	"encoding/json"
	"fmt"
	"os"
	"path/filepath"
	"regexp"
	"strings"

	"github.com/goliatone/go-admin/examples/esign/release"
)

func writeJSON(path string, value any) error {
	raw, err := json.MarshalIndent(value, "", "  ")
	if err != nil {
		return err
	}
	raw = append(raw, '\n')
	return os.WriteFile(path, raw, 0644)
}

func updateLedgerHash(path, entryID, hash string) error {
	raw, err := os.ReadFile(path)
	if err != nil {
		return err
	}

	text := string(raw)
	heading := "## " + strings.TrimSpace(entryID)
	start := strings.Index(text, heading)
	if start < 0 {
		return fmt.Errorf("track c ledger entry not found: %s", entryID)
	}

	sectionEnd := len(text)
	rest := text[start+len(heading):]
	if next := strings.Index(rest, "\n## "); next >= 0 {
		sectionEnd = start + len(heading) + next
	}

	section := text[start:sectionEnd]
	hashLine := "contract_hash: " + hash
	linePattern := regexp.MustCompile(`(?m)^contract_hash:\s*.*$`)
	if linePattern.MatchString(section) {
		section = linePattern.ReplaceAllString(section, hashLine)
	} else {
		if !strings.HasSuffix(section, "\n") {
			section += "\n"
		}
		section += hashLine + "\n"
	}

	updated := text[:start] + section + text[sectionEnd:]
	return os.WriteFile(path, []byte(updated), 0644)
}

func main() {
	repoRoot, err := os.Getwd()
	if err != nil {
		panic(err)
	}

	trackCPath := filepath.Join(repoRoot, "examples/esign/release/trackc_contract_guard.json")
	trackC, err := release.LoadTrackCContractGuard(trackCPath)
	if err != nil {
		panic(err)
	}
	trackCHash, err := release.ComputeContractShapeHash(repoRoot, trackC.TrackedFiles)
	if err != nil {
		panic(err)
	}
	trackC.ContractHash = trackCHash
	if err := writeJSON(trackCPath, trackC); err != nil {
		panic(err)
	}

	ledgerPath := filepath.Join(repoRoot, filepath.FromSlash(strings.TrimSpace(trackC.LedgerPath)))
	if err := updateLedgerHash(ledgerPath, trackC.RequiredLedgerEntryID, trackCHash); err != nil {
		panic(err)
	}

	v2Path := filepath.Join(repoRoot, "examples/esign/release/v2_contract_freeze_guard.json")
	v2Guard, err := release.LoadV2ContractFreezeGuard(v2Path)
	if err != nil {
		panic(err)
	}
	v2Hash, err := release.ComputeContractShapeHash(repoRoot, v2Guard.TrackedFiles)
	if err != nil {
		panic(err)
	}
	v2Guard.ContractHash = v2Hash
	if err := writeJSON(v2Path, v2Guard); err != nil {
		panic(err)
	}

	fmt.Println("updated trackc guard hash:", trackCHash)
	fmt.Println("updated v2 freeze guard hash:", v2Hash)
	fmt.Println("updated trackc ledger entry:", trackC.RequiredLedgerEntryID)
}
EOF

        "${go_bin}" run "${refresh_script}" || {
            rm -f "${refresh_script}"
            exit 1
        }
        rm -f "${refresh_script}"

        "${go_bin}" test ./examples/esign/release -run 'TestValidateTrackCContractGuardPassesForCurrentSnapshot|TestValidateV2ContractFreezeGuardPassesForCurrentSnapshot' -count=1
    )
}

function go:mod:update {
    local modules
    local extra=()
    local mod
    local root
    local latest
    local root_latest
    local resolved
    local current_mod

    if ! command -v rg >/dev/null 2>&1; then
        lgr ERR "rg is required to list goliatone modules"
        return 1
    fi

    # Get current module name to exclude from updates (avoid self-update and submodules)
    current_mod=$(go list -m)

    modules=$(rg -o 'github.com/goliatone/[^[:space:]]+' go.mod | sort -u | grep -v "^${current_mod}")
    if [ -z "$modules" ]; then
        lgr ERR "no goliatone modules found in go.mod"
        return 1
    fi

    lgr I "updating goliatone modules to latest..."
    for mod in $modules; do
        latest=""
        resolved=0
        if latest=$(go list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$mod" 2>/dev/null); then
            resolved=1
        fi

        if [ "$resolved" -eq 1 ] && [ -n "$latest" ]; then
            lgr I "go get ${mod}@${latest}"
            go get "${mod}@${latest}" || return 1
            continue
        fi

        lgr WARN "failed to resolve latest for ${mod}, trying ${mod}@latest"
        if go get -u "${mod}@latest"; then
            continue
        fi

        root=$(echo "$mod" | awk -F/ '{print $1"/"$2"/"$3}')
        if [ "$root" != "$mod" ]; then
            root_latest=""
            if root_latest=$(go list -m -u -f '{{if .Update}}{{.Update.Version}}{{else}}{{.Version}}{{end}}' "$root" 2>/dev/null); then
                lgr WARN "failed to update ${mod}, retrying ${root}@${root_latest}"
                go get "${root}@${root_latest}" || return 1
            else
                lgr WARN "failed to resolve ${root}, retrying ${root}@latest"
                go get -u "${root}@latest" || return 1
            fi
        else
            return 1
        fi
    done

    if [ "$#" -gt 0 ]; then
        for mod in "$@"; do
            extra+=("${mod}@latest")
        done
        lgr I "updating extra modules: ${extra[*]}"
        go get -u "${extra[@]}" || return 1
    fi

    go mod tidy
}

##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:is_greater {
    local left=${1}
    local right=${2}
    local left_identifiers
    local right_identifiers
    local index

    IFS='.' read -ra left_identifiers <<< "$left"
    IFS='.' read -ra right_identifiers <<< "$right"

    if [[ "${#left_identifiers[@]}" -ne 3 || "${#right_identifiers[@]}" -ne 3 ]]; then
        echo "Invalid semver string" >&2
        return 2
    fi

    for index in 0 1 2; do
        if ((10#${left_identifiers[$index]} > 10#${right_identifiers[$index]})); then
            return 0
        fi
        if ((10#${left_identifiers[$index]} < 10#${right_identifiers[$index]})); then
            return 1
        fi
    done

    return 1
}

function version:latest_release_tag {
    git tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname \
        | sed -n 's/^v\([0-9][0-9]*\.[0-9][0-9]*\.[0-9][0-9]*\)$/\1/p' \
        | head -n 1
}

function version:sync_from_tags {
    local file_version
    local latest_tag_version

    version:check

    file_version=$(version:get) || return 1
    latest_tag_version=$(version:latest_release_tag) || return 1

    if [ -z "$latest_tag_version" ]; then
        return 0
    fi

    if version:is_greater "$latest_tag_version" "$file_version"; then
        echo "Syncing ${VERSION_FILE} from ${file_version} to latest release tag ${latest_tag_version}" >&2
        version:set "$latest_tag_version" || return 1
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}

function release:notes:has_content {
    local file=${1}

    if [ -z "${file}" ] || [ ! -f "${file}" ]; then
        return 1
    fi

    awk 'NF { found = 1; exit } END { exit found ? 0 : 1 }' "${file}"
}

function release:notes:assert_temporary {
    local file=${1}

    if [ -z "${file}" ]; then
        return 0
    fi

    if git ls-files --error-unmatch -- "${file}" >/dev/null 2>&1; then
        echo "Release notes file is tracked; refusing to consume it as temporary notes: ${file}" >&2
        echo "Use an ignored scratch file such as .release-notes.md, or set RELEASE_NOTES_FILE to an untracked path." >&2
        return 1
    fi
}

function release:changelog:generate {
    local release_tag=${1}
    local release_notes_file=${2}
    local release_notes

    if release:notes:has_content "${release_notes_file}"; then
        release:notes:assert_temporary "${release_notes_file}" || return 1
        release_notes=$(cat "${release_notes_file}") || return 1
        git cliff --tag "${release_tag}" --with-tag-message "${release_notes}" --output CHANGELOG.md || return 1
        rm -f "${release_notes_file}" || return 1
        echo "Included and removed temporary release notes: ${release_notes_file}" >&2
        return 0
    fi

    git cliff --tag "${release_tag}" --output CHANGELOG.md
}

function release:transaction:backup_file {
    local state_dir=${1}
    local key=${2}
    local path=${3}

    if [ -e "${path}" ]; then
        cp -p "${path}" "${state_dir}/${key}.data" || return 1
        : > "${state_dir}/${key}.present" || return 1
    fi
}

function release:transaction:restore_file {
    local state_dir=${1}
    local key=${2}
    local path=${3}

    if [ -f "${state_dir}/${key}.present" ]; then
        cp -p "${state_dir}/${key}.data" "${path}" || return 1
    else
        rm -f "${path}" || return 1
    fi
}

function release:transaction:backup {
    local state_dir=${1}
    local release_notes_file=${2}

    release:transaction:backup_file "${state_dir}" version "${VERSION_FILE}" || return 1
    release:transaction:backup_file "${state_dir}" changelog CHANGELOG.md || return 1
    release:transaction:backup_file "${state_dir}" root_mod go.mod || return 1
    release:transaction:backup_file "${state_dir}" root_sum go.sum || return 1
    release:transaction:backup_file "${state_dir}" quickstart_mod quickstart/go.mod || return 1
    release:transaction:backup_file "${state_dir}" quickstart_sum quickstart/go.sum || return 1
    release:transaction:backup_file "${state_dir}" release_notes "${release_notes_file}" || return 1
}

function release:transaction:restore {
    local state_dir=${1}
    local release_notes_file=${2}
    local restore_failed=0

    release:transaction:restore_file "${state_dir}" version "${VERSION_FILE}" || restore_failed=1
    release:transaction:restore_file "${state_dir}" changelog CHANGELOG.md || restore_failed=1
    release:transaction:restore_file "${state_dir}" root_mod go.mod || restore_failed=1
    release:transaction:restore_file "${state_dir}" root_sum go.sum || restore_failed=1
    release:transaction:restore_file "${state_dir}" quickstart_mod quickstart/go.mod || restore_failed=1
    release:transaction:restore_file "${state_dir}" quickstart_sum quickstart/go.sum || restore_failed=1
    release:transaction:restore_file "${state_dir}" release_notes "${release_notes_file}" || restore_failed=1

    return "${restore_failed}"
}

function release:transaction:cleanup {
    local state_dir=${1}

    if [ -n "${state_dir}" ] && [ -d "${state_dir}" ]; then
        rm -rf "${state_dir}"
    fi
}

function release:transaction:finish {
    local status=${1}
    local rollback_failed=0

    trap - EXIT

    if [ "${status}" -ne 0 ]; then
        if [ "${release_quickstart_tag_created:-0}" -eq 1 ]; then
            git tag -d "${quickstart_tag}" >/dev/null 2>&1 || rollback_failed=1
        fi
        if [ "${release_root_tag_created:-0}" -eq 1 ]; then
            git tag -d "${release_tag}" >/dev/null 2>&1 || rollback_failed=1
        fi
        if [ "${release_commit_created:-0}" -eq 1 ]; then
            git reset --mixed "${release_original_head}" >/dev/null 2>&1 || rollback_failed=1
        fi
        release:transaction:restore "${release_state_dir}" "${release_notes_file}" || rollback_failed=1
        if [ "${rollback_failed}" -eq 0 ]; then
            echo "Release failed; restored the pre-release working state." >&2
        else
            echo "Release failed and automatic rollback was incomplete; inspect the working tree and local release tags." >&2
        fi
    fi

    release:transaction:cleanup "${release_state_dir}"
    exit "${status}"
}

##
## -----
##
## quickstart:sync
##
## Prepare independently valid root and quickstart module metadata for a shared
## release. Quickstart is tidied through a temporary local root replacement
## because the matching root tag does not exist until the atomic push.
##
## Arguments:
## @arg 1 {string} tag
function quickstart:sync {
    local tag=${1}

    if [ -z "$tag" ]; then
        exit 1
    fi

    if [ ! -f "quickstart/go.mod" ]; then
        return 0
    fi

    GOWORK=off go mod tidy || return 1
    (
        cd quickstart || exit 1
        go mod edit "-require=github.com/goliatone/go-admin@v${tag}" || exit 1
        go mod edit "-replace=github.com/goliatone/go-admin=.." || exit 1
        GOWORK=off go mod tidy || exit 1
        go mod edit -dropreplace=github.com/goliatone/go-admin || exit 1
    ) || return 1

    if grep -Eq '^[[:space:]]*replace[[:space:]]+github\.com/goliatone/go-admin([[:space:]]|$)' quickstart/go.mod; then
        echo "temporary quickstart root replacement was not removed" >&2
        return 1
    fi
}

##
## -----
##
## quickstart:sync:check
##
## Exercise quickstart release preparation against the repository's real
## package graph, then restore module metadata regardless of the result.
##
## Arguments:
## @arg 1 {string} [tag=0.999.0]
function quickstart:sync:check {
    local tag=${1:-0.999.0}
    local state_dir
    local status=0
    local restore_status=0
    local key
    local path

    state_dir=$(mktemp -d "${TMPDIR:-/tmp}/go-admin-quickstart-sync-check.XXXXXX") || return 1
    for path in go.mod go.sum quickstart/go.mod quickstart/go.sum; do
        key=${path//\//_}
        release:transaction:backup_file "${state_dir}" "${key}" "${path}" || {
            release:transaction:cleanup "${state_dir}"
            return 1
        }
    done

    quickstart:sync "${tag}" || status=$?

    for path in go.mod go.sum quickstart/go.mod quickstart/go.sum; do
        key=${path//\//_}
        release:transaction:restore_file "${state_dir}" "${key}" "${path}" || restore_status=1
    done
    release:transaction:cleanup "${state_dir}"

    if [ "${restore_status}" -ne 0 ]; then
        echo "quickstart sync check could not restore module metadata" >&2
        return 1
    fi
    return "${status}"
}

