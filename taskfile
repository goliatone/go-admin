function _webcap_admin:require {
    if ! command -v webcap >/dev/null 2>&1; then
        echo "webcap CLI not found in PATH" >&2
        return 1
    fi
}

function _webcap_admin:base_url {
    local target=$1
    local scheme
    local host_path
    local host

    case "${target}" in
        http://*|https://*)
            scheme="${target%%://*}"
            host_path="${target#*://}"
            host="${host_path%%/*}"
            printf '%s\n' "${scheme}://${host}"
        ;;
        *)
            printf '%s\n' "${WEBCAP_BASE_URL:-http://localhost:8080}"
        ;;
    esac
}

function _webcap_admin:target_url {
    local target=$1
    local base_url=$2

    case "${target}" in
        http://*|https://*) printf '%s\n' "${target}" ;;
        /*) printf '%s\n' "${base_url%/}${target}" ;;
        *) printf '%s\n' "${base_url%/}/${target}" ;;
    esac
}

function _webcap_admin:url_path {
    local target_url=$1
    local without_scheme

    case "${target_url}" in
        http://*|https://*)
            without_scheme="${target_url#*://}"
            if [ "${without_scheme}" = "${without_scheme%%/*}" ]; then
                printf '%s\n' "/"
            else
                printf '/%s\n' "${without_scheme#*/}"
            fi
        ;;
        /*) printf '%s\n' "${target_url}" ;;
        *) printf '/%s\n' "${target_url}" ;;
    esac
}

function _webcap_admin:default_output {
    local url_path=$1
    local slug

    slug="$(printf '%s' "${url_path%%[\?#]*}" \
        | sed -e 's#^/##' -e 's#[^A-Za-z0-9._-]#-#g' -e 's#--*#-#g' -e 's#-$##' -e 's#^$#admin#')"
    printf 'shots/%s.png\n' "${slug}"
}

function _webcap_admin:file_mtime {
    local path=$1

    if stat -f %m "${path}" >/dev/null 2>&1; then
        stat -f %m "${path}"
        return 0
    fi

    stat -c %Y "${path}"
}

function _webcap_admin:cookie_fresh {
    local cookie_jar=$1
    local max_age
    local mtime
    local now
    local age

    if [ ! -s "${cookie_jar}" ]; then
        return 1
    fi

    max_age="${WEBCAP_ADMIN_COOKIE_MAX_AGE_SECONDS:-3600}"
    case "${max_age}" in
        ''|*[!0-9]*)
            echo "WEBCAP_ADMIN_COOKIE_MAX_AGE_SECONDS must be an integer number of seconds" >&2
            return 1
        ;;
    esac
    if [ "${max_age}" -eq 0 ]; then
        return 0
    fi

    mtime="$(_webcap_admin:file_mtime "${cookie_jar}")" || return 1
    now="$(date +%s)"
    age=$((now - mtime))
    [ "${age}" -le "${max_age}" ]
}

function _webcap_admin:login {
    local target_url=$1
    local base_url=$2
    local cookie_jar=$3
    local expect_cookie

    expect_cookie="${WEBCAP_ADMIN_EXPECT_COOKIE:-admin_user}"
    mkdir -p "$(dirname "${cookie_jar}")"
    export WEBCAP_ADMIN_PASSWORD="${WEBCAP_ADMIN_PASSWORD:-superadmin.pwd}"

    webcap auth login \
        --base-url "${base_url}" \
        --login-path "${WEBCAP_ADMIN_LOGIN_PATH:-/admin/login}" \
        --target-url "${target_url}" \
        --cookie-jar "${cookie_jar}" \
        --identifier "${WEBCAP_ADMIN_IDENTIFIER:-superadmin@example.com}" \
        --password-env WEBCAP_ADMIN_PASSWORD \
        --expect-cookie "${expect_cookie}" \
        --timeout "${WEBCAP_AUTH_TIMEOUT:-30s}" \
        --json \
        --no-color || return 1

    webcap auth inspect \
        --cookie-jar "${cookie_jar}" \
        --url "${target_url}" \
        --expect-cookie "${expect_cookie}" \
        --json \
        --no-color >/dev/null
}

function _webcap_admin:ensure_cookie_jar {
    local target_url=$1
    local base_url=$2
    local cookie_jar=$3
    local expect_cookie

    expect_cookie="${WEBCAP_ADMIN_EXPECT_COOKIE:-admin_user}"
    if _webcap_admin:cookie_fresh "${cookie_jar}"; then
        if webcap auth inspect \
            --cookie-jar "${cookie_jar}" \
            --url "${target_url}" \
            --expect-cookie "${expect_cookie}" \
            --json \
            --no-color >/dev/null 2>&1; then
            echo "Using fresh admin cookie jar: ${cookie_jar}"
            return 0
        fi

        echo "Admin cookie jar failed inspection; refreshing: ${cookie_jar}"
    else
        echo "Admin cookie jar is missing or stale; refreshing: ${cookie_jar}"
    fi

    _webcap_admin:login "${target_url}" "${base_url}" "${cookie_jar}"
}

##
## -----
##
## webcap:admin:shot
##
## Capture an authenticated admin page with webcap.
## Creates or refreshes WEBCAP_COOKIE_JAR when it is missing, stale, or fails auth inspection.
##
## Arguments:
## @arg 1 {string} target URL or admin path
## @arg 2 {string} optional output path
function webcap:admin:shot {
    local target=${1:-${TARGET_URL:-${WEBCAP_TARGET_URL:-}}}
    local output=${2:-${WEBCAP_OUTPUT:-}}
    local base_url
    local target_url
    local expect_url
    local cookie_jar

    if [ -z "${target}" ]; then
        echo "Usage: $0 webcap:admin:shot <target-url-or-path> [output]" >&2
        echo "Example: $0 webcap:admin:shot http://localhost:8080/admin/content/pages shots/admin-content-pages.png" >&2
        return 2
    fi

    _webcap_admin:require || return 1

    base_url="$(_webcap_admin:base_url "${target}")"
    target_url="$(_webcap_admin:target_url "${target}" "${base_url}")"
    expect_url="${WEBCAP_EXPECT_URL:-$(_webcap_admin:url_path "${target_url}")}"
    output="${output:-$(_webcap_admin:default_output "${expect_url}")}"
    cookie_jar="${WEBCAP_COOKIE_JAR:-/tmp/admin-cookies.txt}"

    mkdir -p "$(dirname "${output}")"
    _webcap_admin:ensure_cookie_jar "${target_url}" "${base_url}" "${cookie_jar}" || return 1

    webcap shot \
        --cookie-jar "${cookie_jar}" \
        --wait "${WEBCAP_ADMIN_SHOT_WAIT:-4s}" \
        --expect-url "${expect_url}" \
        --fail-on-url "${WEBCAP_ADMIN_LOGIN_PATH:-/admin/login}" \
        --fail-on-selector 'form[action*="/login"]' \
        --output "${output}" \
        "${target_url}"
}

function translation:dashboard:ssr:webcap {
    local channel
    local family_id
    local assignment_id
    local family_route
    local editor_route
    channel="${WEBCAP_CHANNEL:-default}"
