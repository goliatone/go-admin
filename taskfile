function go:lint:baseline {
    local golangci_lint_bin
    local version
    local baseline_path
    local module
    local module_baseline_path
    local module_script
    local -a patterns=()

    version="$(_go:golangci_lint_version)" || return 1
    golangci_lint_bin=$(_go:golangci_lint:ensure "${version}") || return 1
    baseline_path="${GO_QUALITY_BASELINE_DIR}/golangci-lint.txt"
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        while IFS= read -r module; do
            module_script=$(_go:module_relative_path "${module}" "${GO_QUALITY_BASELINE_SCRIPT}")
            module_baseline_path=$(_go:module_relative_path "${module}" "${baseline_path}")
            if [ "${module}" = "." ]; then
                GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${module_script}" check golangci-lint "${module_baseline_path}" ./... || return 1
            else
                (cd "${module}" && GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${module_script}" check golangci-lint "${module_baseline_path}" ./...) || return 1
            fi
        done < <(_go:module_dirs)
        return 0
    fi

    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    GOLANGCI_LINT_BIN="${golangci_lint_bin}" "${GO_QUALITY_BASELINE_SCRIPT}" check golangci-lint "${baseline_path}" "${patterns[@]}"
}

