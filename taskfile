#!/bin/bash

# Check for -debug flag
if [[ $* == *-debug* ]]; then
    set -x
fi

export LGR_NO_TIMESTAMP=true

VERSION_FILE="./.version"

# If we have a .taskenv file load it as source
if [ -f .taskenv ]; then
    # shellcheck disable=SC1091
    source .taskenv
fi

# This makes all bin packages installed via npm available here
# e.g. bogota, nyc, autocannon, etc.
PATH=$(pwd)/node_modules/.bin:$PATH

# This will make all scripts available in the ./src/bin directory
PATH=$(pwd)/src/bin:$PATH

GO_TOOLCHAIN="${GO_TOOLCHAIN:-local}"
GO_GOLANGCI_LINT_VERSION="${GO_GOLANGCI_LINT_VERSION:-v2.12.2}"
GO_GOLANGCI_LINT_VERSION_FILE="${GO_GOLANGCI_LINT_VERSION_FILE:-.golangci-lint-version}"
GO_GOVULNCHECK_VERSION="${GO_GOVULNCHECK_VERSION:-v1.1.4}"
GO_GOSEC_VERSION="${GO_GOSEC_VERSION:-v2.25.0}"
GO_QUALITY_BASELINE_DIR="${GO_QUALITY_BASELINE_DIR:-ops/quality/baselines}"
GO_QUALITY_BASELINE_SCRIPT="${GO_QUALITY_BASELINE_SCRIPT:-./tools/quality/baseline.sh}"
GO_QUALITY_GOCACHE="${GO_QUALITY_GOCACHE:-$(pwd)/.tmp/go-cache}"
GO_QUALITY_GOTMPDIR="${GO_QUALITY_GOTMPDIR:-$(pwd)/.tmp/go-tmp}"
GO_LINT_NEW_FROM_REV="${GO_LINT_NEW_FROM_REV:-origin/main}"


#################################################
# Development dependencies
#################################################

function _install:lgr {
    mkdir -p bin
    if hash lgr 2>/dev/null; then
        lgr OK "lgr already installed..."
    else
        echo "Installing lgr"
        brew tap goliatone/homebrew-tap
        brew install lgr
        lgr OK "lgr installed..."
    fi
}

function _install:changelog {
    if git-cliff lgr 2>/dev/null; then
        lgr OK "git-cliff already installed..."
    else
        echo "Installing lgr"
        brew install brew install orhun/git-cliff/git-cliff
        lgr OK "git-cliff installed..."
    fi
}

function _install:brew {
    if [[ $(command -v brew) == "" ]]; then
        lgr I "Installing Hombrew"
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    else
        lgr I "Updating Homebrew"
        brew update
    fi
}

function _install:envset {
    if hash envset 2>/dev/null; then
        lgr OK "envset installed..."
    else
        lgr I "Installing envset..."
        brew install envset
        lgr OK "envset installed..."
    fi
}

function _go:bin {
    if command -v go >/dev/null 2>&1; then
        command -v go
        return 0
    fi

    echo "go binary not found in PATH" >&2
    return 1
}

function _go:quality:prepare_env {
    export GOCACHE="${GOCACHE:-${GO_QUALITY_GOCACHE}}"
    export GOTMPDIR="${GOTMPDIR:-${GO_QUALITY_GOTMPDIR}}"
    mkdir -p "${GOCACHE}" "${GOTMPDIR}"
}

function _go:golangci_lint_version {
    if [ -f "${GO_GOLANGCI_LINT_VERSION_FILE}" ]; then
        awk 'NF { print $1; exit }' "${GO_GOLANGCI_LINT_VERSION_FILE}"
        return 0
    fi

    printf '%s\n' "${GO_GOLANGCI_LINT_VERSION}"
}

function _go:tool_bin_dir {
    local go_bin
    local gobin
    local gopath

    go_bin=$(_go:bin) || return 1
    gobin="$("${go_bin}" env GOBIN)"
    if [ -n "${gobin}" ]; then
        printf '%s\n' "${gobin}"
        return 0
    fi

    gopath="$("${go_bin}" env GOPATH)"
    if [ -n "${gopath}" ]; then
        printf '%s\n' "${gopath%/}/bin"
        return 0
    fi

    echo "unable to resolve Go tool bin directory" >&2
    return 1
}

function _go:tool:path {
    local name=$1
    local bin_dir

    if command -v "${name}" >/dev/null 2>&1; then
        command -v "${name}"
        return 0
    fi

    bin_dir=$(_go:tool_bin_dir) || return 1
    if [ -x "${bin_dir}/${name}" ]; then
        printf '%s\n' "${bin_dir}/${name}"
        return 0
    fi

    return 1
}

function _go:tool:install {
    local name=$1
    local target=$2
    local go_bin

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    echo "Installing ${name} (${target})" >&2
    GOTOOLCHAIN="${GO_TOOLCHAIN}" "${go_bin}" install "${target}" || return 1
    _go:tool:path "${name}" || return 1
}

function _go:tool:ensure {
    local name=$1
    local target=$2
    local tool_path

    if tool_path=$(_go:tool:path "${name}" 2>/dev/null); then
        printf '%s\n' "${tool_path}"
        return 0
    fi

    _go:tool:install "${name}" "${target}"
}

function _go:golangci_lint:ensure {
    local version=$1
    local tool_path

    if tool_path=$(_go:tool:path "golangci-lint" 2>/dev/null); then
        if "${tool_path}" version 2>/dev/null | grep -q "version ${version#v}"; then
            printf '%s\n' "${tool_path}"
            return 0
        fi
    fi

    _go:tool:install "golangci-lint" "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${version}"
}

function _go:module_dirs {
    printf '%s\n' "."
    if [ -f "quickstart/go.mod" ]; then
        printf '%s\n' "quickstart"
    fi
    if [ -f "examples/go.mod" ]; then
        printf '%s\n' "examples"
    fi
}

function _go:module_relative_path {
    local module=$1
    local path=$2
    local prefix

    if [[ "${path}" = /* ]]; then
        printf '%s\n' "${path}"
        return 0
    fi

    if [ "${module}" = "." ]; then
        printf '%s\n' "${path}"
        return 0
    fi

    path="${path#./}"
    prefix=$(printf '%s\n' "${module}" | sed 's#[^/][^/]*#..#g')
    printf '%s/%s\n' "${prefix}" "${path}"
}

function _go:run_in_modules {
    local module

    while IFS= read -r module; do
        if [ "${module}" = "." ]; then
            "$@" || return 1
        else
            (cd "${module}" && "$@") || return 1
        fi
    done < <(_go:module_dirs)
}

function _go:packages {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    if [ "$#" -gt 0 ]; then
        patterns=("$@")
        "${go_bin}" list "${patterns[@]}"
        return 0
    fi

    _go:run_in_modules "${go_bin}" list ./...
}

function _go:package_dirs {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    if [ "$#" -gt 0 ]; then
        patterns=("$@")
        "${go_bin}" list -f '{{.Dir}}' "${patterns[@]}"
        return 0
    fi

    _go:run_in_modules "${go_bin}" list -f '{{.Dir}}' ./...
}

function _go:files {
    find . -type f -name '*.go' \
        -not -path './.git/*' \
        -not -path './.gocache/*' \
        -not -path './.tmp/*' \
        -not -path './node_modules/*' \
        -not -path './pkg/client/assets/node_modules/*' \
        | sort
}

function _go:lint:patterns {
    if [ "$#" -gt 0 ]; then
        printf '%s\n' "$@"
        return 0
    fi

    printf '%s\n' "./..."
}

##########################################
# Application management
##########################################

function go:tools:golangci-lint {
    local version

    version="$(_go:golangci_lint_version)" || return 1
    _go:tool:install "golangci-lint" "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${version}"
}

function go:tools:govulncheck {
    _go:tool:install "govulncheck" "golang.org/x/vuln/cmd/govulncheck@${GO_GOVULNCHECK_VERSION}"
}

function go:tools:gosec {
    _go:tool:install "gosec" "github.com/securego/gosec/v2/cmd/gosec@${GO_GOSEC_VERSION}"
}

function go:tools:all {
    go:tools:golangci-lint || return 1
    go:tools:govulncheck || return 1
    go:tools:gosec || return 1
}

function go:fmt {
    local gofmt_bin
    local -a files=()

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    "${gofmt_bin}" -w "${files[@]}"
}

function go:fix {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${go_bin}" fix ./...
        return $?
    fi

    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    "${go_bin}" fix "${patterns[@]}"
}

function go:fmt:check {
    local gofmt_bin
    local -a files=()
    local unformatted

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    unformatted="$("${gofmt_bin}" -l "${files[@]}")"
    if [ -n "${unformatted}" ]; then
        echo "The following Go files need formatting:"
        echo "${unformatted}"
        return 1
    fi
}

function go:test {
    local go_bin
    local -a packages=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${go_bin}" test ./...
        return $?
    fi

    while IFS= read -r pkg; do
        if [ -n "${pkg}" ]; then
            packages+=("${pkg}")
        fi
    done < <(_go:packages "$@")
    "${go_bin}" test "${packages[@]}"
}

function go:race {
    local go_bin
    local -a packages=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${go_bin}" test -race -count=1 ./...
        return $?
    fi

    while IFS= read -r pkg; do
        if [ -n "${pkg}" ]; then
            packages+=("${pkg}")
        fi
    done < <(_go:packages "$@")
    "${go_bin}" test -race -count=1 "${packages[@]}"
}

function go:cover {
    local go_bin
    local module
    local -a packages=()
    local output_file=${GO_COVERPROFILE:-coverage.out}

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        while IFS= read -r module; do
            if [ "${module}" = "." ]; then
                "${go_bin}" test -coverprofile="${output_file}" ./... && "${go_bin}" tool cover -func "${output_file}" || return 1
            else
                (cd "${module}" && "${go_bin}" test -coverprofile="${output_file}" ./... && "${go_bin}" tool cover -func "${output_file}") || return 1
            fi
        done < <(_go:module_dirs)
        return 0
    fi

    while IFS= read -r pkg; do
        if [ -n "${pkg}" ]; then
            packages+=("${pkg}")
        fi
    done < <(_go:packages "$@")
    "${go_bin}" test -coverprofile="${output_file}" "${packages[@]}" && "${go_bin}" tool cover -func "${output_file}"
}

function go:vet {
    local go_bin
    local -a packages=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
