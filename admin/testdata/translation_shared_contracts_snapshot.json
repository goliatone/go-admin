        "label": "Review Overdue",
        "query": {
          "due_state": "overdue",
          "order": "asc",
          "reviewer_id": "__me__",
          "sort": "due_date",
          "status": "review"
        }
      },
      {
        "description": "Reviewer inbox items with blocking QA findings.",
